---
import { getUi } from '../../lib/i18n';

const ui = getUi('en').resume;
const fileName = 'seokho-lee-resume-en.pdf';
const resumeUrl = '/en/resume.pdf';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>{ui.downloadTitle}</title>
  </head>
  <body>
    <a id="resume-download" href={resumeUrl} download={fileName}>{ui.downloadLink}</a>
    <script is:inline>
      document.getElementById('resume-download')?.click();
    </script>
  </body>
</html>
